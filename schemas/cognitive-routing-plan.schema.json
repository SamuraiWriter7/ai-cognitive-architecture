{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/cognitive-routing-plan.schema.json",
  "title": "Cognitive Routing Plan",
  "description": "Defines a selected cognitive route across specialized cognitive organs for one cognitive task or cycle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "routing_plan_id",
    "architecture_id",
    "created_at",
    "input_profile",
    "routing_mode",
    "selected_route",
    "route_policy",
    "fallback_policy",
    "human_escalation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3"
    },
    "routing_plan_id": {
      "type": "string",
      "minLength": 1
    },
    "architecture_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_profile": {
      "$ref": "#/$defs/inputProfile"
    },
    "routing_mode": {
      "type": "string",
      "enum": [
        "minimal",
        "standard",
        "deep_structure",
        "safety_review",
        "memory_intensive",
        "custom"
      ]
    },
    "selected_route": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/routeStep"
      }
    },
    "route_policy": {
      "$ref": "#/$defs/routePolicy"
    },
    "fallback_policy": {
      "$ref": "#/$defs/fallbackPolicy"
    },
    "human_escalation": {
      "$ref": "#/$defs/humanEscalation"
    },
    "routing_summary": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "organType": {
      "type": "string",
      "enum": [
        "finder",
        "yin_semantic_decomposer",
        "memory_breathing",
        "analyst",
        "structural_core",
        "verifier",
        "boundary",
        "yang_language_recomposer",
        "human_gate",
        "structural_rumination",
        "custom"
      ]
    },
    "inputProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_type",
        "complexity",
        "uncertainty",
        "risk_level",
        "memory_dependency",
        "external_information_dependency"
      ],
      "properties": {
        "task_type": {
          "type": "string",
          "enum": [
            "simple_answer",
            "translation",
            "summarization",
            "analysis",
            "design",
            "verification",
            "decision_support",
            "open_research",
            "safety_sensitive",
            "custom"
          ]
        },
        "complexity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "uncertainty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk_level": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "memory_dependency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "external_information_dependency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "required_capabilities": {
          "$ref": "#/$defs/stringArray"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "routeStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "order",
        "organ",
        "activation",
        "reason"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "organ": {
          "$ref": "#/$defs/organType"
        },
        "activation": {
          "type": "string",
          "enum": [
            "required",
            "conditional",
            "optional",
            "fallback"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "activation_condition": {
          "type": "string"
        },
        "skip_condition": {
          "type": "string"
        },
        "expected_inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "expected_outputs": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "routePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_loops",
        "max_loop_count",
        "allow_parallel_branches",
        "require_verification_before_output",
        "require_boundary_before_output"
      ],
      "properties": {
        "allow_loops": {
          "type": "boolean"
        },
        "max_loop_count": {
          "type": "integer",
          "minimum": 0
        },
        "allow_parallel_branches": {
          "type": "boolean"
        },
        "require_verification_before_output": {
          "type": "boolean"
        },
        "require_boundary_before_output": {
          "type": "boolean"
        },
        "preferred_return_routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/returnRoute"
          }
        },
        "termination_conditions": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "returnRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "condition"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/organType"
        },
        "to": {
          "$ref": "#/$defs/organType"
        },
        "condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fallbackPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "on_missing_artifact",
        "on_validation_failure",
        "on_route_block"
      ],
      "properties": {
        "on_missing_artifact": {
          "type": "string",
          "enum": [
            "return_to_predecessor",
            "invoke_finder",
            "invoke_memory_breathing",
            "route_to_human_gate",
            "stop_cycle"
          ]
        },
        "on_validation_failure": {
          "type": "string",
          "enum": [
            "return_to_analyst",
            "return_to_structural_core",
            "route_to_human_gate",
            "stop_cycle"
          ]
        },
        "on_route_block": {
          "type": "string",
          "enum": [
            "route_to_boundary",
            "route_to_human_gate",
            "stop_cycle"
          ]
        },
        "max_recovery_attempts": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "humanEscalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "conditions"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "conditions": {
          "$ref": "#/$defs/stringArray"
        },
        "presentation_requirements": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  }
}
